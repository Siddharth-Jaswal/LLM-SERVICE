# -----------------------------
# LLM Provider Configuration
# -----------------------------
# Choose your provider: "lmstudio" or "openai"
LLM_PROVIDER=lmstudio

# If using openai, set your key here:
OPENAI_API_KEY=your_sk_key_here

# Where is LM Studio running? (Used if LLM_PROVIDER=lmstudio)
LMSTUDIO_URL=http://localhost:1234
# Which model should we target?
MODEL=qwen3-vl-8b-instruct

# -----------------------------
# Gateway API Configuration
# -----------------------------
# What host and port should THIS FastAPI project run on?
API_HOST=0.0.0.0
API_PORT=8000
